# Application
NODE_ENV=development
PORT=3000

# JWT
JWT_SECRET=wellnest_jwt_secret_key_change_in_production_2024
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=wellnest_refresh_secret_key_change_in_production_2024
JWT_REFRESH_EXPIRES_IN=30d

# Firebase (Optional - for production)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_PRIVATE_KEY=your-private-key
# FIREBASE_CLIENT_EMAIL=your-client-email

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:4200

# Database (Firestore Emulator for development)
# FIRESTORE_EMULATOR_HOST=localhost:8080
